# ── AI ────────────────────────────────────────────────────────────────────────
AI_PROVIDER=gemini
AI_PROVIDER_API_KEY=
AI_MODEL=gemini-2.5-flash

# ── Image Generation ──────────────────────────────────────────────────────────
CREATIVE_PROVIDER=pollinations
CREATIVE_PROVIDER_API_KEY=

# ── Meta Graph API (Facebook + Instagram) ────────────────────────────────────
META_GRAPH_VERSION=v21.0
META_ACCESS_TOKEN=          # Facebook Page Access Token
INSTAGRAM_ACCESS_TOKEN=     # Instagram User Access Token (graph.instagram.com)
META_PAGE_ID=               # Numeric Facebook Page ID
META_IG_USER_ID=            # Numeric Instagram Business Account ID

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=product-assets

# ── Scrapers ──────────────────────────────────────────────────────────────────
SERPAPI_API_KEY=
SERPAPI_TIMEOUT=15
SERPAPI_MAX_RESULTS=5
MAX_CONCURRENCY=10
DEFAULT_TIMEOUT=30
SCRAPER_HEADLESS=true
MAX_RESULTS_PER_TARGET=5

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agentic_marketing

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
APP_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
