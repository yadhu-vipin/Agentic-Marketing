# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (auth + database + storage) ─────────────────────────────────────
# Leave blank to run in local demo mode (in-memory store, demo user, no auth).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket name for product images/logos (create it in Supabase).
SUPABASE_STORAGE_BUCKET=product-assets

# ── AI content generation ────────────────────────────────────────────────────
# Provider: gemini | openai | anthropic | demo (deterministic fallback)
AI_PROVIDER=gemini
AI_PROVIDER_API_KEY=
# Optional model override
AI_MODEL=gemini-2.5-flash

# ── Creative (image) generation ──────────────────────────────────────────────
# Provider: pollinations (free, no key) | openai | stability
CREATIVE_PROVIDER=pollinations
CREATIVE_PROVIDER_API_KEY=

# ── Meta Graph API (Facebook Pages + Instagram Business) ─────────────────────
# Required for real publishing. Create a Meta app + long-lived page token.
META_GRAPH_VERSION=v21.0
META_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=
